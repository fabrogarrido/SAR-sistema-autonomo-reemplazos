      "parameters": {
        "jsCode": "const respuesta = $input.first().json.data;\nconst contexto = $('Split Fechas').first().json;\n\nconst fechasAceptadas = respuesta['¿Qué fechas podés cubrir?'] || [];\nconst puedeCubrir = respuesta['¿Podés cubrir alguna?'] === 'Sí, las seleccionadas arriba';\n\n// Fechas que quedan sin cubrir\nconst fechasRestantes = contexto.guardiasPendientes.filter(f => !fechasAceptadas.includes(f));\n\nreturn [{\n  json: {\n    puedeCubrir: puedeCubrir,\n    fechasAceptadas: fechasAceptadas,\n    fechasRestantes: fechasRestantes,\n    solicitante: contexto.solicitante,\n    motivo: contexto.motivo,\n    diaGuardia: contexto.diaGuardia,\n    totalGuardias: contexto.totalGuardias,\n    candidatos: contexto.candidatos,\n    indiceCandidato: contexto.indiceCandidato,\n    nombreCandidato: contexto.candidatos[0].NOMBRE\n  }\n}];"
      },
