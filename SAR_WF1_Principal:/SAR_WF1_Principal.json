    {
      "parameters": {
        "jsCode": "// Toma datos del trigger\nconst item = $input.first().json;\n\nconst nombreSolicitante = item[\"Nombre y apellido\"];\nconst motivo = item[\"Motivo de la licencia\"];\nconst diaGuardia = item[\"¿Qué día de la semana es tu guardia fija?\"]\n  .toUpperCase()\n  .normalize(\"NFD\")\n  .replace(/[\\u0300-\\u036f]/g, \"\"); // Elimina tildes y minusculas\n\nconst fechaInicio = new Date(\n  item[\"Fecha de INICIO de la licencia\"]\n    .split(\"/\").reverse().join(\"-\") // \"11/05/2026\" → \"2026-05-11\"\n);\nconst fechaFin = new Date(\n  item[\"Fecha de FIN de la licencia\"]\n    .split(\"/\").reverse().join(\"-\")\n);\n\n// Mapa de días\nconst diasSemana = {\n  \"LUNES\": 1, \"MARTES\": 2, \"MIERCOLES\": 3,\n  \"JUEVES\": 4, \"VIERNES\": 5, \"SABADO\": 6, \"DOMINGO\": 0\n};\n\nconst numeroDia = diasSemana[diaGuardia];\n\n// Busca todas las fechas que caen en ese día dentro del rango\nconst guardiasEncontradas = [];\nconst cursor = new Date(fechaInicio);\n\nwhile (cursor <= fechaFin) {\n  if (cursor.getDay() === numeroDia) {\n    guardiasEncontradas.push(cursor.toISOString().split(\"T\")[0]); // \"2026-05-12\"\n  }\n  cursor.setDate(cursor.getDate() + 1);\n}\n\nreturn [{\n  json: {\n    solicitante: nombreSolicitante,\n    motivo: motivo,\n    diaGuardia: diaGuardia,\n    guardiasPendientes: guardiasEncontradas,\n    totalGuardias: guardiasEncontradas.length\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        -160
      ],
      "id": "57527ef6-de42-40e3-904f-899bf3c31b90",
      "name": "Expandir Fechas"
    },
    {
      "parameters": {
        "jsCode": "// Datos del primer Node Code (guardias)\nconst solicitud = $('Expandir Fechas').first().json;\nconst diaGuardia = solicitud.diaGuardia;\nconst guardiasPendientes = solicitud.guardiasPendientes;\n\n// Todos los profesionales del Google Sheets\nconst profesionales = $input.all().map(item => item.json);\n\n// Filtro: ACTIVO, que tenga el día en su DISPONIBILIDAD y que NO sea el solicitante\nconst candidatos = profesionales\n  .filter(p => {\n    if (p.ESTADO !== \"ACTIVO\") return false;\n    if (p.NOMBRE === solicitud.solicitante) return false; // Excluir al solicitante\n    const diasDisponibles = p.DISPONIBILIDAD.split(\",\").map(d => d.trim());\n    return diasDisponibles.includes(diaGuardia);\n  })\n  .sort((a, b) => a.PRIORIDAD - b.PRIORIDAD);\n\nreturn [{\n  json: {\n    solicitante: solicitud.solicitante,\n    motivo: solicitud.motivo,\n    diaGuardia: diaGuardia,\n    guardiasPendientes: guardiasPendientes,\n    totalGuardias: guardiasPendientes.length,\n    candidatos: candidatos\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        48
      ],
      "id": "aac8088f-7ee3-4b71-be5d-c9db9233160e",
      "name": "Filtrar Candidatos"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\n// Formateamos todas las fechas pendientes a DD/MM/YYYY\nconst guardiasPendientesFormateadas = data.guardiasPendientes.map(fecha => {\n  const [anio, mes, dia] = fecha.split(\"-\");\n  return `${dia}/${mes}/${anio}`;\n});\n\n// La primera fecha formateada para referencia\nconst fechaFormateada = guardiasPendientesFormateadas[0];\nconst fechaOriginal = data.guardiasPendientes[0];\n\nreturn [{\n  json: {\n    fecha: fechaFormateada,\n    fechaOriginal: fechaOriginal,\n    solicitante: data.solicitante,\n    motivo: data.motivo,\n    diaGuardia: data.diaGuardia,\n    totalGuardias: data.totalGuardias,\n    guardiasPendientes: guardiasPendientesFormateadas,\n    guardiasPendientesISO: data.guardiasPendientes,\n    candidatos: data.candidatos,\n    indiceCandidato: 0\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        48
      ],
